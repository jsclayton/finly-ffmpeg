# Downloaded upstream source + verified tarball (reproduced by fetch-ffmpeg.sh)
/vendor/

# Per-arch build trees and intermediate installs
/build/

# Pipeline outputs: xcframeworks, exported headers, LGPL bundle
/artifacts/

# The FFmpeg API headers under Sources/CFFmpeg/include/libav*|libsw* ARE
# tracked, deliberately: a SwiftPM checkout compiles the CFFmpeg module from
# git content alone (the binary targets deliver only the dylibs), so the
# headers are part of the consumable package, not build debris. They are
# regenerated by make-xcframeworks.sh on every build; a diff there means the
# FFmpeg version changed and belongs in the same commit as the bump.

# SwiftPM
/.build/
/.swiftpm/
Package.resolved

# Local build logs
/build-log.txt

# macOS
.DS_Store
