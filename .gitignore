# Downloaded upstream source + verified tarball (reproduced by fetch-ffmpeg.sh)
/vendor/

# Per-arch build trees and intermediate installs
/build/

# Pipeline outputs: xcframeworks, exported headers, LGPL bundle
/artifacts/

# Generated FFmpeg headers vendored into the CFFmpeg module by the build.
# CFFmpeg.h + module.modulemap + shim.c are tracked; the vendored header trees
# (libavutil/libavcodec/libavformat/libswresample) are not.
/Sources/CFFmpeg/include/libav*/
/Sources/CFFmpeg/include/libsw*/

# Compiled test-fixture origin server (source is tracked; the binary is not)
/scripts/tools/rangeserver/rangeserver

# SwiftPM
/.build/
/.swiftpm/
Package.resolved

# macOS
.DS_Store
